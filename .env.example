# Coach Circle — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to git. This file (.env.example) is safe to commit.

# ─── GoHighLevel (GHL) URLs ───────────────────────────────────────────────────
# All CTA destinations point to GHL. Paste real URLs from your GHL account.

GHL_APPLY_URL=
GHL_LOGIN_URL=
GHL_CALENDAR_URL=
GHL_COMMUNITY_URL=
GHL_NEWSLETTER_URL=
GHL_COURSES_BASE=
GHL_CHECKOUT_TIER1=
GHL_CHECKOUT_TIER2=

# ─── Analytics ────────────────────────────────────────────────────────────────
GA4_MEASUREMENT_ID=

# ─── Contribute Site (for /contribute rewrite in vercel.json) ─────────────────
CONTRIBUTE_SITE_URL=https://coach-circle-site.vercel.app

# ─── Site Meta ────────────────────────────────────────────────────────────────
SITE_URL=https://coachcircle.ph
